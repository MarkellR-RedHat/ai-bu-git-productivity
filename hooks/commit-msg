#!/usr/bin/env bash
# ai-bu-git-productivity/hooks/commit-msg
# Suggests conventional commit format. Never blocks.
#
# Install:
#   cp hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

set -euo pipefail

MSG_FILE="$1"
MSG=$(head -1 "$MSG_FILE")

# Strip leading whitespace
MSG_TRIMMED=$(echo "$MSG" | sed 's/^[[:space:]]*//')

# Skip auto-generated messages
if echo "$MSG_TRIMMED" | grep -qE '^(Merge|Revert|WIP:|fixup!|squash!|Initial commit)'; then
  exit 0
fi

warnings=0

VALID_TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# ---- Check conventional commit format ----------------------------------------

if ! echo "$MSG_TRIMMED" | grep -qE "^(${VALID_TYPES})(\([a-zA-Z0-9_-]+\))?: .+"; then
  # Try to suggest a prefix based on what files were changed
  staged_files=$(git diff --cached --name-only 2>/dev/null || echo "")
  suggested_type="feat"

  if echo "$staged_files" | grep -qiE '(readme|docs/|\.md$)'; then
    suggested_type="docs"
  elif echo "$staged_files" | grep -qiE '(test|spec|__test__)'; then
    suggested_type="test"
  elif echo "$staged_files" | grep -qiE '(\.ya?ml$|dockerfile|makefile|\.toml$|\.cfg$|\.ini$)'; then
    suggested_type="build"
  elif echo "$staged_files" | grep -qiE '(\.github/|\.circleci|jenkinsfile|\.gitlab-ci)'; then
    suggested_type="ci"
  elif echo "$staged_files" | grep -qiE '(\.css$|\.scss$|\.less$|\.styled\.)'; then
    suggested_type="style"
  fi

  echo ""
  echo "NOTE: Your commit message is not in conventional format."
  echo ""
  echo "  Your message:   $MSG_TRIMMED"
  echo "  Suggested fix:  $suggested_type: $(echo "$MSG_TRIMMED" | sed 's/^[A-Z]/\L&/')"
  echo ""
  echo "  Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo "  Format:      type: description"
  echo "               type(scope): description"
  echo ""
  echo "  Proceeding with your original message. Use 'git commit --amend' to change it."
  echo ""
  warnings=$((warnings + 1))
fi

# ---- Check subject line length -----------------------------------------------
msg_len=${#MSG_TRIMMED}

if [ "$msg_len" -gt 72 ]; then
  echo "NOTE: Subject line is $msg_len characters (recommended max is 72)."
  echo "  Move details to the commit body instead."
  echo ""
  warnings=$((warnings + 1))
fi

# ---- Check minimum description length ----------------------------------------
description=$(echo "$MSG_TRIMMED" | sed -E "s/^(${VALID_TYPES})(\([a-zA-Z0-9_-]+\))?: //" 2>/dev/null || echo "$MSG_TRIMMED")
desc_len=${#description}

if [ "$desc_len" -lt 10 ]; then
  echo "NOTE: Description is short ($desc_len chars). More detail helps future you."
  echo "  Your message: \"$MSG_TRIMMED\""
  echo ""
  warnings=$((warnings + 1))
fi

# ---- Check for trailing period ------------------------------------------------
if echo "$MSG_TRIMMED" | grep -qE '\.$'; then
  echo "NOTE: Subject line ends with a period. Convention is to leave it off."
  echo ""
  warnings=$((warnings + 1))
fi

# ---- Summary ----------------------------------------------------------------
if [ "$warnings" -gt 0 ]; then
  echo "Commit message: $warnings suggestion(s) above. Commit proceeds."
fi

# Always allow the commit to proceed
exit 0
